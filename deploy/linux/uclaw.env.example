NODE_ENV=production
PORT=3001
# Must be the final public origin. Do not use "*".
CORS_ORIGIN=https://your-domain.example.com
UCLAW_DATA_PATH=.uclaw

# Optional lightweight settings gate password.
# This only hides the settings page from casual passers-by.
# UCLAW_SETTINGS_ACCESS_PASSWORD=123@456

UCLAW_API_BASE_URL=https://api.openai.com/v1
UCLAW_API_KEY=replace_me
UCLAW_DEFAULT_MODEL=gpt-5.4

# Optional Feishu
# UCLAW_FEISHU_APP_ID=
# UCLAW_FEISHU_APP_SECRET=
# UCLAW_FEISHU_AGENT_ROLE_KEY=organizer
# UCLAW_FEISHU_API_BASE_URL=
# UCLAW_FEISHU_APP_NAME=

# Optional Daily Memory
# UCLAW_DAILY_MEMORY_API_BASE_URL=
# UCLAW_DAILY_MEMORY_API_KEY=
# UCLAW_DAILY_MEMORY_MODEL=
# UCLAW_DAILY_MEMORY_API_FORMAT=openai

# Optional Skills MCP Assistant
# UCLAW_SKILLS_MCP_ASSISTANT_API_URL=
# UCLAW_SKILLS_MCP_ASSISTANT_API_KEY=

# Optional IMA
# IMA_OPENAPI_CLIENTID=
# IMA_OPENAPI_APIKEY=
