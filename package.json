{
  "name": "uclaw",
  "version": "0.3.0",
  "description": "UCLAW - AI-powered personal assistant with local web UI",
  "private": true,
  "packageManager": "npm@10.0.0",
  "type": "module",
  "author": {
    "name": "UCLAW"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "bin": {
    "uclaw": "./server/dist/server/src/cli.js"
  },
  "main": "./server/dist/server/src/index.js",
  "files": [
    "server/dist",
    "server/public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node scripts/dev-runner.mjs",
    "web:dev": "vite --config vite.config.web.ts",
    "dev:web": "node scripts/dev-runner.mjs",
    "rehearsal:migration": "node scripts/migration-rehearsal.mjs",
    "build": "npm run build:web && npm run build:server",
    "bundle": "node scripts/bundle.mjs",
    "build:web": "vite build --config vite.config.web.ts --outDir server/public",
    "web:build": "vite build --config vite.config.web.ts --outDir server/public",
    "build:server": "tsc -p server/tsconfig.json && node -e \"require('fs').writeFileSync('server/dist/package.json','{\\\"type\\\":\\\"module\\\"}\\n')\" && node scripts/fix-imports.mjs && node -e \"require('fs').copyFileSync('server/shims/electron.cjs','server/dist/server/shims/electron.cjs')\"",
    "server:build": "tsc -p server/tsconfig.json && node -e \"require('fs').writeFileSync('server/dist/package.json','{\\\"type\\\":\\\"module\\\"}\\n')\" && node scripts/fix-imports.mjs && node -e \"require('fs').copyFileSync('server/shims/electron.cjs','server/dist/server/shims/electron.cjs')\"",
    "start": "node scripts/start-smart.mjs --host 0.0.0.0 --no-open",
    "start:frontend-gateway": "node scripts/start-frontend-gateway.mjs",
    "start:local": "node scripts/start-smart.mjs --host 127.0.0.1",
    "server:start": "node server/dist/server/src/cli.js --no-open --host 0.0.0.0",
    "deploy:check": "node scripts/preflight-deploy.mjs",
    "deploy:init": "node scripts/generate-deploy-preset.mjs",
    "package:delivery:linux": "node scripts/create-standard-delivery-bundle.mjs",
    "package:desktop-control": "node scripts/package-desktop-control-mcp.mjs",
    "server:dev": "tsx watch server/start-server.ts",
    "lint": "eslint src server scripts --ext .ts,.tsx,.mjs --report-unused-disable-directives --max-warnings 0",
    "lint:current": "eslint src server scripts --ext .ts,.tsx,.mjs --report-unused-disable-directives --max-warnings 0",
    "typecheck:web": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "check:current": "npm run typecheck:web && npm run typecheck:server && npm run lint:current",
    "test:server": "node --import tsx --test tests/server/**/*.test.ts",
    "test:server:api": "node --import tsx --test tests/server/api.test.ts",
    "test:server:ws": "node --import tsx --test tests/server/websocket.test.ts",
    "test:web": "node --test tests/web/**/*.test.ts",
    "test:all": "npm run test:server",
    "preview": "vite preview --config vite.config.web.ts",
    "build:skill:web-search": "npm install --prefix SKILLs/web-search && npx tsc -p SKILLs/web-search/tsconfig.json",
    "build:skill:tech-news": "node scripts/build-skill-tech-news.js",
    "build:skill:email": "cd SKILLs/imap-smtp-email && npm install --production",
    "build:skills": "npm run build:skill:web-search && npm run build:skill:tech-news && npm run build:skill:email",
    "bind:skill:blingbling-eye": "tsx scripts/bind-blingbling-little-eye.ts",
    "clean-room:smoke": "node scripts/run-clean-room-smoke.mjs",
    "package:web-clean": "node scripts/refresh-clean-web-package.mjs",
    "guard:app-config": "node --import tsx scripts/check-app-config-guard.mjs",
    "smoke:cowork": "node scripts/smoke-cowork-session.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.12",
    "@anthropic-ai/sdk": "^0.32.1",
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@monaco-editor/react": "^4.7.0",
    "@playwright/mcp": "^0.0.40",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^2.2.1",
    "@types/uuid": "^10.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "extract-zip": "^2.0.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.21",
    "mammoth": "^1.12.0",
    "mermaid": "^10.9.5",
    "monaco-editor": "^0.55.1",
    "open": "^10.0.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.0.0",
    "react-redux": "^9.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sql.js": "^1.13.0",
    "uuid": "^11.1.0",
    "ws": "^8.14.2",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/extract-zip": "^2.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/sql.js": "^1.4.9",
    "@types/ws": "^8.5.10",
    "@types/yazl": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.35",
    "rimraf": "^5.0.5",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^5.1.4",
    "vite-tsconfig-paths": "^4.3.2",
    "wait-on": "^7.2.0"
  }
}
