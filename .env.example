# ==============================================================================
# UCLAW 环境变量模板
# 用法：
# 1. 复制本文件为 .env
# 2. 只填“必填 / 推荐填写”部分
# 3. Linux 自动化 / CI/CD / systemd 无人值守部署，不要依赖首启后再去 UI 补配置
# 3. 不确定的先留空，系统会优先读 .env，没有时再读数据库设置
# ------------------------------------------------------------------------------
# 注意：
# - 主变量统一使用 UCLAW_* 命名
# - 运行时兼容旧别名 LOBSTERAI_*，但新部署不要再写旧名字
# - 自动化平台通常会注入 PORT，请不要强行写死成别的平台端口
# ==============================================================================

# ------------------------------------------------------------------------------
# A. 基础运行配置
# ------------------------------------------------------------------------------
# 当前模板默认偏本地开发。
# 若用于 Linux / Render / Zeabur / systemd 等生产部署，请直接参考 deploy/linux/uclaw.env.example，
# 并把 NODE_ENV 改为 production。
# 开发环境：development
# 生产环境：production
NODE_ENV=development

# 默认端口是 3001。
# Render / Railway / Koyeb / Zeabur 等平台通常会自动注入 PORT，
# 这时保留默认值即可，平台值会覆盖它。
PORT=3001

# 允许跨域来源。
# 单体部署可先用 *；
# 若前后端分离，建议改成明确域名，如 https://your-domain.com
# 注意：当前服务端启用 credentials=true；生产前后端分离时不要继续保留 *
CORS_ORIGIN=*

# ------------------------------------------------------------------------------
# B. 数据目录与工作目录
# ------------------------------------------------------------------------------
# 默认数据目录为：./.uclaw/web
# 若要自定义，请务必放在“项目根目录内部”，否则运行时会自动忽略并回退默认目录。
# 推荐：
# UCLAW_DATA_PATH=.uclaw
# 或平台项目内绝对路径：
# UCLAW_DATA_PATH=/opt/render/project/src/.uclaw
# UCLAW_DATA_PATH=

# 一般不用手填。服务启动时会自动推断项目根目录。
# 只有在非常规启动方式下才需要覆盖。
# UCLAW_APP_ROOT=
# UCLAW_WORKSPACE=

# 设置页轻门禁密码（可选）
# 仅用于挡一下旁观者，不属于真实安全边界。
# 不填则前端不弹密码框，直接打开设置页。
# UCLAW_SETTINGS_ACCESS_PASSWORD=123@456

# ------------------------------------------------------------------------------
# C. 模型 API 配置
# ------------------------------------------------------------------------------
# 这是最常用的一组配置。
# 人工值守首启时，可以暂时留空后再去 UI 设置页填写。
# Linux 自动化 / systemd / CI 无人值守部署时，必须在启动前提供这三项
# （或等效预置到数据库），不要把“UI 后补”当成生产基线。
UCLAW_API_BASE_URL=
UCLAW_API_KEY=
UCLAW_DEFAULT_MODEL=

# 示例：
# UCLAW_API_BASE_URL=https://api.openai.com/v1
# UCLAW_API_KEY=sk-xxxx
# UCLAW_DEFAULT_MODEL=gpt-5.4

# ------------------------------------------------------------------------------
# C2. 前端部署指向（重要）
# ------------------------------------------------------------------------------
# 这一组是“前端页面要指向哪个 UCLAW 服务端”的部署期变量。
# 不填时，前端默认走同源：
# - HTTP -> /api
# - WebSocket -> /ws
# 这适合单域名 / 单外网端口 / 反向代理已收口的平台。
#
# 如果前端和后端分开部署，只建议先填一项：
# VITE_BACKEND_ORIGIN=https://your-backend.example.com
# 前端会自动推导：
# - API_BASE = https://your-backend.example.com/api
# - WS_URL   = wss://your-backend.example.com/ws
#
# 只有当你的 API / WS 入口不是这套标准路径时，才单独覆盖下面两项。
# VITE_BACKEND_ORIGIN=
# VITE_PUBLIC_API_BASE=
# VITE_PUBLIC_WS_URL=

# ------------------------------------------------------------------------------
# D. 飞书集成（可选）
# ------------------------------------------------------------------------------
# 只有要启用飞书机器人时才填写。
# 不填不会影响普通 Web 使用。
# 默认为飞书官方地址；只有走私有化或代理场景才需要覆盖。
# UCLAW_FEISHU_APP_ID=
# UCLAW_FEISHU_APP_SECRET=
# UCLAW_FEISHU_AGENT_ROLE_KEY=organizer
# UCLAW_FEISHU_API_BASE_URL=
# UCLAW_FEISHU_APP_NAME=

# ------------------------------------------------------------------------------
# E. 每日记忆摘要模型（可选）
# ------------------------------------------------------------------------------
# 如果想把“每日记忆总结”绑定到单独的小模型，可填写这组。
# 不填则沿用主配置或数据库设置。
# UCLAW_DAILY_MEMORY_API_BASE_URL=
# UCLAW_DAILY_MEMORY_API_KEY=
# UCLAW_DAILY_MEMORY_MODEL=Qwen/Qwen3.5-4B
# UCLAW_DAILY_MEMORY_API_FORMAT=openai

# ------------------------------------------------------------------------------
# F. Skills MCP Assistant（可选）
# ------------------------------------------------------------------------------
# 仅当启用对应桥接能力时才填写。
# UCLAW_SKILLS_MCP_ASSISTANT_API_URL=
# UCLAW_SKILLS_MCP_ASSISTANT_API_KEY=

# ------------------------------------------------------------------------------
# G. IMA（可选）
# ------------------------------------------------------------------------------
# 仅当启用 IMA 相关能力时才填写；也可能由设置页同步到运行目录。
# IMA_OPENAPI_CLIENTID=
# IMA_OPENAPI_APIKEY=

# ------------------------------------------------------------------------------
# H. 高级运行时（一般不要手填）
# ------------------------------------------------------------------------------
# 仅用于非常规打包/资源布局场景；标准 Linux 主机部署通常不需要覆盖。
# UCLAW_RESOURCES_ROOT=

# ------------------------------------------------------------------------------
# I. 兼容说明
# ------------------------------------------------------------------------------
# 以下旧变量名仍兼容读取，但不建议新项目继续使用：
# - LOBSTERAI_APP_ROOT
# - LOBSTERAI_WORKSPACE
# - LOBSTERAI_DATA_PATH
# - LOBSTERAI_API_BASE_URL
# - LOBSTERAI_API_KEY
# - LOBSTERAI_DEFAULT_MODEL
